# Copy this file to `.env` and fill in your Supabase project values.
# Found in the Supabase dashboard → Project Settings → API.
# The publishable key (sb_publishable_…) is a *public* client key, safe to ship to the
# browser — the database is protected by Row-Level Security, not by hiding this key.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Where the recipe-scraper serverless function lives.
# - PWA on Vercel: leave unset — it defaults to the same-origin "/api/scrape".
# - Electron desktop build: set this to your deployed URL, e.g.
#     VITE_SCRAPE_URL=https://your-recipevault.vercel.app/api/scrape
# VITE_SCRAPE_URL=

# Only used by scripts/migrate-to-supabase.mjs (one-time SQLite → Supabase import).
# Your Supabase login, so migrated rows are stamped with your user id. Not shipped.
# MIGRATE_EMAIL=you@example.com
# MIGRATE_PASSWORD=your-password
